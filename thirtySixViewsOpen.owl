Prefix: rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
Prefix: rdfs: <http://www.w3.org/2000/01/rdf-schema#>
Prefix: xml: <http://www.w3.org/XML/1998/namespace>
Prefix: xsd: <http://www.w3.org/2001/XMLSchema#>



Ontology: <http://www.semanticweb.org/james/ontologies/2018/0/36-Views-of-Mount-Fuji>


AnnotationProperty: rdfs:comment

    
Datatype: rdf:PlainLiteral

    
Datatype: xsd:int

    
Datatype: xsd:string

    
ObjectProperty: depictsConstruction

    
ObjectProperty: depictsRooftops

    
ObjectProperty: hasAHorse

    
ObjectProperty: hasTwoMountFujis

    
ObjectProperty: indoorScene

    
ObjectProperty: owl:topObjectProperty

    
ObjectProperty: redMountFuji

    SubPropertyOf: 
        owl:topObjectProperty
    
    
ObjectProperty: rooftopsForeground

    SubPropertyOf: 
        depictsRooftops
    
    
Class: Agriculture_Theme

    SubClassOf: 
        View_of_Mount_Fuji
    
    
Class: Animals_Motif

    SubClassOf: 
        View_of_Mount_Fuji
    
    
Class: Bodies_Of_Water_Motif

    SubClassOf: 
        View_of_Mount_Fuji
    
    
Class: Disjoint_Union_People_Mount_Fuji_Foreground

    SubClassOf: 
        View_of_Mount_Fuji
    
    DisjointUnionOf: 
        Mount_Fuji_Foreground, People_Motif
    
    
Class: Horse_Motif

    SubClassOf: 
        Animals_Motif
    
    
Class: Maritime_Theme

    SubClassOf: 
        Bodies_Of_Water_Motif
    
    
Class: Mount_Fuji_Background

    SubClassOf: 
        View_of_Mount_Fuji
    
    DisjointWith: 
        Mount_Fuji_Foreground
    
    
Class: Mount_Fuji_Foreground

    SubClassOf: 
        View_of_Mount_Fuji
    
    DisjointWith: 
        Mount_Fuji_Background
    
    
Class: People_Motif

    SubClassOf: 
        View_of_Mount_Fuji
    
    DisjointWith: 
        WIldlife_Not_People
    
    
Class: Urbanisation_Theme

    SubClassOf: 
        View_of_Mount_Fuji
    
    
Class: View_of_Mount_Fuji

    Annotations: 
        rdfs:comment "Group Axioms guideline: all restrictions for a class should be in a single restriction. While owl:Thing and View_of_Mount_Fuji contain the same members they are functionally different in terms of what they restrict. In this case it is more informative to have two separate classes despite this being less parsimonious."@en
    
    SubClassOf: 
        owl:Thing
    
    
Class: WIldlife_Not_People

    SubClassOf: 
        View_of_Mount_Fuji,
        Wildlife_Motif
    
    DisjointWith: 
        People_Motif
    
    
Class: Wildlife_And_Bodies_of_Water

    SubClassOf: 
        View_of_Mount_Fuji,
        Bodies_Of_Water_Motif
         and Wildlife_Motif
    
    
Class: Wildlife_Motif

    SubClassOf: 
        Animals_Motif
    
    
Class: owl:Thing

    Annotations: 
        rdfs:comment "OWL is built on an open-world assumption, however 36 Views of Mount Fuji is a closed-world ontology. This ontology has an exact cardinality of 36."@en
    
    
